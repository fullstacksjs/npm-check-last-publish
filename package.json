{
  "name": "npm-check-last-publish",
  "version": "0.1.22",
  "description": "A simple CLI tool that helps developers check the last published versions of their project dependencies.",
  "repository": {
    "type": "git",
    "url": "https://github.com/fullstacksjs/npm-check-last-publish"
  },
  "keywords": [
    "last-publish",
    "check-publish",
    "package.json",
    "npm",
    "publish"
  ],
  "license": "MIT",
  "author": "Mahdi Sheibak <mahdi.zoraghi.sheibak@gmail.com>",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "npm-check-last-publish": "dist/src/main.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "dev": "node src/main.ts",
    "prepare": "husky",
    "spell": "cspell .",
    "test:watch": "node --watch --test 'src/**/*.spec.ts'",
    "test": "node --test 'src/**/*.spec.ts'"
  },
  "dependencies": {
    "cli-progress": "3.12.0",
    "cli-table3": "0.6.5",
    "commander": "14.0.0",
    "temporal-polyfill": "0.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.2.0",
    "@commitlint/config-conventional": "20.2.0",
    "@fullstacksjs/eslint-config": "13.12.0",
    "@semantic-release/github": "12.0.2",
    "@semantic-release/npm": "13.1.3",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/cli-progress": "3.11.6",
    "@types/node": "24.1.0",
    "cspell": "9.4.0",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "prettier": "3.7.4",
    "semantic-release": "25.0.2",
    "typescript": "5.9.3"
  },
  "volta": {
    "node": "22.20.0",
    "npm": "11.6.2"
  }
}
